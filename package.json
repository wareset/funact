{
  "name": "funact",
  "version": "0.0.1",
  "description": "A lightweight, blazing fast React-like UI library based strictly on functional components and hooks",
  "keywords": [
    "funact",
    "react-like",
    "hooks",
    "fast",
    "ui"
  ],
  "license": "MIT",
  "homepage": "https://github.com/wareset/funact",
  "bugs": {
    "url": "https://github.com/wareset/funact/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wareset/funact.git"
  },
  "author": "rease <cftcview@gmail.com>",
  "main": "dist/index",
  "module": "dist/index.mjs",
  "types": "types/index.d.ts",
  "files": [
    "README.md",
    "dist/**/*",
    "index.d.ts",
    "types/**/*"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./types/index.d.ts"
    },
    "./jsx-runtime": {
      "import": "./dist/jsx-runtime/index.mjs",
      "require": "./dist/jsx-runtime/index.js",
      "types": "./types/jsx-runtime.d.ts"
    }
  },
  "scripts": {
    "build": "dester -m --out dist",
    "dev": "dester -mw --out dist",
    "gen": "node ./gen/index.mjs",
    "gen-dev": "nodemon --watch ./gen --ext mjs --inspect ./gen/index.mjs"
  },
  "devDependencies": {
    "dester": "1.0.x",
    "nodemon": "^3.1.1",
    "jsdom": "^29.0.0",
    "@types/jsdom": "^28.0.0",
    "puppeteer": "^24.40.0",
    "svg-element-attributes": "^2.1.0",
    "html-element-attributes": "^3.5.0"
  },
  "dependencies": {
    "csstype": "3.x"
  },
  "peerDependencies": {
    "typescript": "*"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}